# Roam environment variables.
# Copy to .env.local and fill in real values there.
# This repo is PUBLIC: real keys NEVER go in git — .env* is gitignored,
# only this example file is committed, with placeholders only.

# Supabase (V1.S2.T3) — server-side only; the browser never sees these.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key

# Direct/pooled Postgres connection — only if direct SQL is ever needed
# (migrations run via Supabase MCP/CLI instead):
#   DATABASE_URL=postgresql://...pooler.supabase.com:6543/postgres

# Coming with V1.S4.T1 (planning brain):
#   ANTHROPIC_API_KEY=your-api-key

# Clerk autospawn (npm run fire:clerk — SETUP §cloud accounts, Clerk
# routine): per-machine; generate the fire token ONCE in the routine's
# API-trigger UI, routine id from the routine's URL.
CLERK_FIRE_TOKEN=your-fire-token
CLERK_ROUTINE_ID=your-routine-id
